{
  "name": "leasing-platform-backend",
  "version": "1.0.0",
  "description": "Austrian Car Leasing Platform - Backend API",
  "main": "dist/server.js",
  "scripts": {
    "setup": "npx prisma db push --skip-generate && npm run prisma:seed",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest --forceExit",
    "test:unit": "jest --testPathPattern=engine --forceExit",
    "test:integration": "jest --testPathPattern=integration --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --testPathPattern=engine --coverage --forceExit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@types/nodemailer": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "decimal.js": "^10.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-async-errors": "^3.1.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.7",
    "pdfkit": "^0.15.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.9.1",
    "@types/pdfkit": "^0.13.5",
    "@types/supertest": "^6.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.7",
    "jest": "^29.7.0",
    "prisma": "^5.22.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/__tests__"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "projects": [
      {
        "displayName": "unit",
        "preset": "ts-jest",
        "globals": { "ts-jest": { "tsconfig": "tsconfig.test.json" } },
        "testEnvironment": "node",
        "testMatch": [
          "<rootDir>/__tests__/engine/**/*.test.ts"
        ],
        "collectCoverageFrom": [
          "<rootDir>/src/engine/**/*.ts"
        ],
        "coverageThreshold": {
          "global": {
            "branches": 100,
            "functions": 100,
            "lines": 100,
            "statements": 100
          }
        }
      },
      {
        "displayName": "integration",
        "preset": "ts-jest",
        "globals": { "ts-jest": { "tsconfig": "tsconfig.test.json" } },
        "testEnvironment": "node",
        "testMatch": [
          "<rootDir>/__tests__/integration/**/*.test.ts"
        ]
      }
    ]
  }
}
